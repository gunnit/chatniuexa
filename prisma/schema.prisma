// Prisma schema for ChatAziendale.it
// NextAuth + Multi-tenant architecture

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// Enable pgvector extension for embeddings
// Run: CREATE EXTENSION IF NOT EXISTS vector;

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// NextAuth Models
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // For Credentials provider
  image         String?
  role          String    @default("user") // "user" | "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts            Account[]
  sessions            Session[]
  profile             Profile?
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────
// Password Reset
// ─────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────────────────────
// Multi-tenant Models
// ─────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("free") // free, pro, business
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profiles      Profile[]
  dataSources   DataSource[]
  chatbots      Chatbot[]
  subscriptions Subscription[]

  @@map("tenants")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  tenantId  String
  fullName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("profiles")
}

// ─────────────────────────────────────────────────────────────
// Subscription Model (PayPal Billing)
// ─────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  SUSPENDED
  EXPIRED
}

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String
  planId                String             // 'pro' or 'business'
  paypalSubscriptionId  String             @unique
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([paypalSubscriptionId])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────
// Document Ingestion Models (Phase 2)
// ─────────────────────────────────────────────────────────────

enum DataSourceType {
  FILE
  URL
}

enum DataSourceStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

model DataSource {
  id        String           @id @default(cuid())
  tenantId  String
  type      DataSourceType
  status    DataSourceStatus @default(PENDING)
  name      String           // Display name (filename or URL title)

  // For FILE type
  fileName  String?
  fileType  String?          // MIME type: application/pdf, text/plain, etc.
  fileSize  Int?             // Size in bytes
  fileUrl   String?          // Storage URL (e.g., S3, Vercel Blob)

  // For URL type
  sourceUrl String?          // Original URL to crawl

  // Processing info
  error     String?          // Error message if failed
  lastSyncAt DateTime?       // When last synced (for URL re-crawl)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([tenantId])
  @@index([status])
  @@map("data_sources")
}

model Document {
  id           String   @id @default(cuid())
  dataSourceId String
  title        String?
  content      String   @db.Text  // Full extracted text
  metadata     Json?              // Additional metadata (page count, etc.)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  chunks     Chunk[]

  @@index([dataSourceId])
  @@map("documents")
}

model Chunk {
  id         String   @id @default(cuid())
  documentId String
  content    String   @db.Text           // Chunk text
  chunkIndex Int                         // Order within document
  tokens     Int?                        // Token count

  // Vector embedding stored via raw SQL (pgvector)
  // embedding vector(1536)  -- Added via migration

  createdAt  DateTime @default(now())

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("chunks")
}

// ─────────────────────────────────────────────────────────────
// Chatbot & Conversation Models (Phase 3)
// ─────────────────────────────────────────────────────────────

model Chatbot {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?

  // Configuration
  systemPrompt String?  @db.Text  // Custom instructions
  temperature  Float    @default(0.7)
  model        String   @default("gpt-5.4-mini")

  // Tools (Phase 1) — when any tool is enabled the bot answers via the
  // OpenAI Responses API instead of Chat Completions.
  webSearchEnabled Boolean @default(false)  // OpenAI-hosted web_search tool (Pro+)

  // Realtime voice (Business) — when enabled the widget shows a "Talk" button that
  // opens a WebRTC speech-to-speech session grounded in this bot's knowledge base.
  voiceEnabled Boolean @default(false)
  voiceName    String  @default("marin")  // OpenAI Realtime voice (marin, cedar, ...)

  // Widget customization (Phase 5)
  primaryColor     String?  @default("#3B82F6")
  secondaryColor   String?  @default("#6366f1")
  welcomeEyebrow   String?  @default("Knowledge assistant")    // Small label above headline (blank to hide)
  welcomeHeadline  String?  @default("Hi — what would you like to *know*?")  // Big hero title; *word* renders in accent color
  welcomeMessage   String?  @default("Hello! How can I help you?")
  showBranding     Boolean  @default(true)
  showSources      Boolean  @default(true)  // Show "Sources:" citations on public chat/widget
  suggestedPrompts String[] @default([])  // Quick reply suggestions

  // Chat icon customization
  chatIconType   String?  @default("default")  // "default" | "preset" | "custom"
  chatIconPreset String?                        // e.g. "headset", "robot", "help"
  chatIconImage  String?  @db.Text              // base64 data URL (~2-8KB)

  // Public sharing
  shareToken   String?  @unique               // Short token for public chat URL (/c/<token>)

  // Embed restriction — list of customer domains permitted to call /api/chat* and /api/widget/[id].
  // Empty list = unrestricted (back-compat). Match is on hostname; subdomains match too.
  allowedDomains String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  whatsappConfig WhatsAppConfig?
  mcpServers     ChatbotMcpServer[]
  voiceSessions  VoiceSession[]
  leads          Lead[]

  @@index([tenantId])
  @@map("chatbots")
}

// Remote MCP server a tenant has attached to a bot (Business plan).
// The bot can call this server's read-only tools via the OpenAI Responses API.
// Approval is handled at CONFIG time (the tenant picks `allowedTools`); calls
// then run with require_approval:"never" — runtime approval is nonsensical for
// anonymous end-user chat. `authToken` is AES-256-GCM ciphertext, never returned
// to the client.
model ChatbotMcpServer {
  id           String   @id @default(cuid())
  chatbotId    String
  label        String   // server_label sent to OpenAI (slug, unique per bot)
  serverUrl    String   // server_url (https only, SSRF-guarded)
  description  String?  // server_description (helps the model pick the server)
  authToken    String?  @db.Text  // AES-256-GCM ciphertext of the Bearer token; nullable for no-auth servers
  allowedTools String[] @default([])  // explicit allowlist — empty list means the bot cannot call anything
  enabled      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@unique([chatbotId, label])
  @@index([chatbotId])
  @@map("chatbot_mcp_servers")
}

model Conversation {
  id        String   @id @default(cuid())
  chatbotId String
  sessionId String   // Anonymous session identifier
  channel   String   @default("web")  // "web" | "whatsapp" | "voice"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  chatbot  Chatbot   @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([chatbotId])
  @@index([sessionId])
  @@map("conversations")
}

enum MessageRole {
  USER
  ASSISTANT
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text

  // For assistant messages: sources used
  sources        Json?       // Array of { chunkId, content, similarity, documentTitle }

  // User feedback
  reaction       String?     // 'up' or 'down' - user reaction to this message

  createdAt      DateTime    @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// ─────────────────────────────────────────────────────────────
// WhatsApp Integration
// ─────────────────────────────────────────────────────────────

model WhatsAppConfig {
  id                        String   @id @default(cuid())
  chatbotId                 String   @unique
  phoneNumberId             String   @unique  // Meta phone number ID (for webhook routing)
  whatsappBusinessAccountId String?
  accessToken               String   @db.Text  // Encrypted via AES-256-GCM
  webhookVerifyToken        String             // Random token for Meta webhook verification
  isActive                  Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([phoneNumberId])
  @@map("whatsapp_configs")
}

// ─────────────────────────────────────────────────────────────
// Analytics & Usage Models (Phase 9)
// ─────────────────────────────────────────────────────────────

model UsageLog {
  id        String   @id @default(cuid())
  tenantId  String
  chatbotId String?
  type      String   // 'chat', 'embedding', 'crawl'
  tokens    Int      @default(0)
  cost      Float    @default(0)  // Estimated cost in USD

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([chatbotId])
  @@index([createdAt])
  @@map("usage_logs")
}

model UsageLimit {
  id            String   @id @default(cuid())
  tenantId      String   @unique

  // Limits
  monthlyTokenLimit  Int      @default(100000)    // Tokens per month
  dailyMessageLimit  Int      @default(1000)      // Messages per day
  monthlyCostLimit   Float    @default(10.0)      // USD per month
  monthlyVoiceMinutes Int     @default(0)         // Realtime voice minutes per month (Business)

  // Current usage (reset monthly/daily)
  currentMonthTokens  Int      @default(0)
  currentMonthCost    Float    @default(0)
  currentMonthVoiceSeconds Int @default(0)        // Realtime voice seconds used this month
  currentDayMessages  Int      @default(0)
  lastDayReset        DateTime @default(now())
  lastMonthReset      DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usage_limits")
}

// ─────────────────────────────────────────────────────────────
// Realtime Voice (Business)
// ─────────────────────────────────────────────────────────────

// Server-issued ledger for one WebRTC voice session. Its `id` is the opaque
// sessionId handed to the browser; every voice endpoint (retrieve/lead/heartbeat)
// authorizes against it. `secondsUsed` is updated on each heartbeat so cost is
// captured even if the tab is abandoned without a clean end.
model VoiceSession {
  id          String   @id @default(cuid())
  chatbotId   String
  tenantId    String   // denormalized for fast metering without a join
  secondsUsed Int      @default(0)
  status      String   @default("active")  // "active" | "ended" | "expired"
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  leads   Lead[]

  @@index([chatbotId])
  @@index([createdAt])
  @@map("voice_sessions")
}

// A lead captured by the voice bot (the "AI receptionist" story). Also reusable
// by future channels. PII here is intentional/consented — the visitor gave it.
model Lead {
  id             String   @id @default(cuid())
  chatbotId      String
  tenantId       String   // denormalized
  voiceSessionId String?
  name           String?
  email          String?
  phone          String?
  note           String?  @db.Text
  source         String   @default("voice")  // "voice" | future channels
  createdAt      DateTime @default(now())

  chatbot      Chatbot       @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  voiceSession VoiceSession? @relation(fields: [voiceSessionId], references: [id], onDelete: SetNull)

  @@index([chatbotId])
  @@index([createdAt])
  @@map("leads")
}
